// week09-2 好玩的程式設計 (打地鼠冒出來) - 完整可執行版
void setup() { 
  size(300, 300); // 視窗大小 300 x 300
}

// 宣告並初始化 3x3 的二維陣列 (地圖資料)
int [][] a = { 
  {0, 0, 0}, 
  {0, 0, 0}, 
  {0, 0, 0} 
}; 
void mousePressed() { // week10-1 新加的程式: mouse按下去
  
  // 1. 座標轉換：把滑鼠位置換算成陣列的索引值 (i, j)
  int i = mouseY / 100, j = mouseX / 100; // 左手i對應Y座標 右手j對應X座標
  
  // 2. 判定命中
  if ( a[i][j] > 0 ) { // 陣列數值大於 0，代表這裡有一隻活著的地鼠！
    
    // 3. 改變狀態：擊中！
    a[i][j] = -60; // 由正變負，負的代表死掉的地鼠（準備在 draw 畫出流血死掉的特效）
  }
}

void draw() { // 每秒畫60次
  background(#FFFFF2); // 背景淡黃色
  
  // --- 新增：自動生成地鼠的邏輯 ---
  // frameCount 是一個內建變數，記錄程式目前跑到第幾個影格
  // 每 60 個影格 (約 1 秒鐘)，就隨機挑選一個洞讓地鼠冒出來
  if (frameCount % 60 == 0) {
    int randomI = int(random(3)); // 隨機產生 0, 1, 2
    int randomJ = int(random(3)); // 隨機產生 0, 1, 2
    a[randomI][randomJ] = 60;     // 把選中洞的數值設為 60
  }
  // ---------------------------------

  // 畫出 3x3 的九宮格與地鼠
  for (int i=0; i<3; i++) { 
    for (int j=0; j<3; j++) { 
      int x = 50 + j*100; // 計算 X 座標
      int y = 50 + i*100; // 計算 Y 座標
      
      if (a[i][j] > 0) {
        // 如果陣列數值大於 0，畫出帶有透明度的暗紅色地鼠
        fill(#C61616, a[i][j] * 4); 
        a[i][j]--; // 數值每回合減 1，產生慢慢透明不見的動畫
      } else {
        // 如果陣列數值為 0，填上背景色當作空洞
        fill(#FFFFF2); 
      }
      
      ellipse(x, y, 90, 90); // 畫出圓形
    }
  }
}
